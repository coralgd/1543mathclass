rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEMO MODE (без Firebase Auth):
    // Позволяет регистрацию/вход через Firestore-документы.
    // В продакшене обязательно перейти на Firebase Auth.
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
